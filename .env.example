# GCP / BigQuery (required for load + dbt)
GCP_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# BigQuery datasets
BQ_RAW_DATASET=gratuity_raw
BQ_STAGING_DATASET=gratuity_staging
BQ_MARTS_DATASET=gratuity_marts

# Data source: "sample" (local CSV) or "sheets" (Google Sheets API)
DATA_SOURCE=sample

# Google Sheets (only when DATA_SOURCE=sheets)
GOOGLE_SHEETS_ID=your-spreadsheet-id
SHEETS_SHIFTS_TAB=Shifts
SHEETS_DAILY_TIPS_TAB=DailyTips

# Business rules
AUTO_GRATUITY_RATE=0.19
EXPECTED_SHIFT_HOURS=8.0

# Pipeline
PIPELINE_RUN_DATE=
